# ─────────────────────────────────────────────────────────────────────────────
# JRP International – Environment Variables
#
# Copy this file to .env.local for local development with `wrangler pages dev`.
# For production, set these in Cloudflare Pages → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Resend API key – get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The inbox that receives enquiry emails (must be in your Resend domain)
TO_EMAIL=praveen@jrp-international.com

# The verified "from" address (domain must be verified in Resend)
FROM_EMAIL=JRP International <noreply@jrp-international.com>
